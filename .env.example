# AegisDesk Environment Configuration Template

# ------------------------------------------------------------------------------
# LLM Providers (Required: At least one)
# ------------------------------------------------------------------------------
# OpenAI (Default for general tasks)
OPENAI_API_KEY=sk-...

# Groq (Recommended for sub-second semantic routing and fast Llama-3 inference)
GROQ_API_KEY=gsk_...

# Google Gemini (Optional)
GOOGLE_API_KEY=...

# ------------------------------------------------------------------------------
# API Security (Required)
# ------------------------------------------------------------------------------
# Secret key for signing JWT tokens in the FastAPI application
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=your-secure-jwt-secret-key-here

# ------------------------------------------------------------------------------
# LangGraph Configuration
# ------------------------------------------------------------------------------
# Prevent infinite recursion / Denial of Wallet attacks
MAX_TOOL_RECURSION=3

# ------------------------------------------------------------------------------
# Cloud & Integration Tools (Optional, but required for Cloud Agent)
# ------------------------------------------------------------------------------
# Azure
AZURE_SUBSCRIPTION_ID=...
AZURE_TENANT_ID=...
AZURE_CLIENT_ID=...
AZURE_CLIENT_SECRET=...

# AWS
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Atlassian (Jira / Confluence)
ATLASSIAN_API_TOKEN=...
ATLASSIAN_DOMAIN=yourcompany.atlassian.net
ATLASSIAN_USER_EMAIL=admin@yourcompany.com
